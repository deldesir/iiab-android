<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dash_bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/rounded_button"
            android:backgroundTint="@color/dash_module_bg"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="16dp"  android:paddingBottom="10dp"
            android:layout_marginBottom="16dp"
            android:gravity="top"
            android:baselineAligned="false"
            android:weightSum="4">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/led_install_termux"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_termux"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/led_install_dev_mode"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_dev_options"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_led_dcpr"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/led_install_dcpr"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/txt_install_dcpr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_child_process"
                    android:textColor="@color/dash_text_secondary"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/container_led_ppk"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <View
                    android:id="@+id/led_install_ppk"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/led_off"
                    android:layout_marginBottom="4dp" />
                <TextView
                    android:id="@+id/txt_install_ppk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_led_ppk"
                    android:textColor="@color/dash_text_secondary"
                    android:textSize="10sp"
                    android:gravity="center"
                    android:lines="2" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/section_adv_monitoring"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/txt_adv_monitoring_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/install_adv_monitoring_title"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary"
                android:paddingVertical="8dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/dash_divider"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/container_adv_monitoring"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/adb_desc_monitoring"
                    android:textColor="@color/dash_text_secondary"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btn_adb_action"
                        android:layout_width="0dp"
                        android:layout_height="60dp"
                        android:layout_weight="1"
                        android:text="@string/adb_btn_connect"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="#2196F3"
                        android:textAllCaps="false"
                        android:layout_marginEnd="16dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="60dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/rounded_button"
                        android:backgroundTint="@color/dash_module_bg"
                        android:paddingHorizontal="24dp">

                        <View
                            android:id="@+id/led_adb_status"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:background="@drawable/led_off"
                            android:layout_marginBottom="4dp" />

                        <TextView
                            android:id="@+id/txt_adb_led_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/adb_status_offline"
                            android:textColor="@color/dash_text_secondary"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:orientation="vertical"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="@color/dash_module_bg"
                    android:padding="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/adb_graph_title"
                        android:textColor="@color/dash_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp"
                        android:layout_marginStart="8dp"/>

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/cpu_chart"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_header_fast"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_divider"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_desc_fast"
            android:textColor="@color/dash_text_primary"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_fast_install"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="@string/install_btn_install"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#008000"
                android:layout_marginEnd="8dp"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/btn_fast_delete"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_weight="1"
                android:text="@string/install_btn_delete"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#FF0000"
                android:layout_marginStart="8dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/txt_module_mgmt_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/install_header_roles"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:textSize="18sp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />

            <TextView
                android:id="@+id/btn_refresh_modules"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Refresh"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="12dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_divider"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/container_module_mgmt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/install_modules_disclaimer"
                android:textColor="@color/dash_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:id="@+id/install_roles_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp">
            </LinearLayout>

            <LinearLayout
                android:id="@+id/install_discrepancy_warning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#44FF0000"
                android:padding="12dp"
                android:layout_marginBottom="24dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/install_warning_discrepancy_icon"
                    android:textColor="#FF5555"
                    android:textSize="16sp"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/txt_discrepancy_msg"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/install_warning_discrepancy_msg"
                    android:textColor="#FFCCCC"
                    android:textSize="12sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_launch_install"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/install_btn_launch"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/rounded_button"
                android:backgroundTint="#008000"
                android:layout_marginBottom="32dp"
                android:textAllCaps="false" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_maintenance_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/install_header_maintenance"
            android:textColor="?android:attr/textColorPrimary"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="8dp" />
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/dash_divider"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:id="@+id/container_maintenance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/install_desc_maintenance"
                android:textColor="@color/dash_text_primary"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/btn_advanced_backup"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/install_btn_backup"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#2196F3"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_advanced_reset"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/install_btn_reset"
                    android:textColor="#000000"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#FFC107"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="8dp"
                android:baselineAligned="false">

                <Button
                    android:id="@+id/btn_advanced_restore"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="4dp"
                    android:text="@string/install_btn_restore"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#4CAF50"
                    android:textAllCaps="false" />

                <Button
                    android:id="@+id/btn_advanced_force_stop"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginStart="4dp"
                    android:text="@string/install_btn_force_stop"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/rounded_button"
                    android:backgroundTint="#F44336"
                    android:textAllCaps="false" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:id="@+id/txt_select_backup_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/install_adv_select_backup"
                    android:textColor="?android:attr/textColorPrimary"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackground" />

                <LinearLayout
                    android:id="@+id/container_backup_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/txt_backup_status"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/install_msg_fetching_backups"
                        android:textColor="@color/dash_text_secondary"
                        android:textSize="12sp"
                        android:textStyle="italic"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>
</ScrollView>