<div id="panel-books" class="app-panel pb-2 hidden-section">

    <div class="mb-4 pt-2">
        <h4 class="fw-bold mb-1">📚 Books Downloader</h4>
        <p class="text-secondary small mb-3">A curated catalog of over 1,000 books powered by Project Gutenberg</p>
        <hr class="border-secondary opacity-25">
    </div>

    <div class="mb-4">
        <div class="input-group input-group-lg shadow-sm">
            <span class="input-group-text bg-surface border-end-0 text-secondary">🔍</span>
            <input type="text" class="form-control border-start-0 ps-2" id="global-book-search" placeholder="Search local or remote catalog..." onkeyup="handleGlobalSearch(this.value)">
        </div>
    </div>

    <ul class="nav nav-tabs mb-4 border-secondary" id="books-tab-nav">
        <li class="nav-item">
            <a class="nav-link active cursor-pointer fw-bold" id="nav-local" onclick="switchBookTab('local')">📚 My Local Books</a>
        </li>
        <li class="nav-item">
            <a class="nav-link cursor-pointer fw-bold" id="nav-top" onclick="switchBookTab('top')">🏆 Top 100</a>
        </li>
        <li class="nav-item">
            <a class="nav-link cursor-pointer fw-bold" id="nav-edu" onclick="switchBookTab('educational')">🎓 Educational & Children</a>
        </li>
    </ul>

    <div id="books-action-bar" class="d-flex justify-content-between align-items-center mb-3 hidden-section">
        <div class="d-flex align-items-center"></div>
        <button id="books-batch-download-btn" class="btn btn-success disabled" onclick="downloadSelectedBooks()">
            DOWNLOAD
        </button>
    </div>

    <div id="books-content-container">
        </div>
</div>

<div class="modal fade" id="bookLimitWarningModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-surface text-body border-warning">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title text-warning fw-bold">
                    ⚠️ Suggested Download Limit
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Please complete the downloads in the queue first. Help use Project Gutenberg's bandwidth responsibly.
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-outline-light" data-bs-dismiss="modal">GOT IT</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="bookDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-surface text-body border-secondary">
            <div class="modal-header border-bottom-0">
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body text-center pt-0">
                <img id="modal-cover-img" src="" class="img-fluid rounded mb-3 shadow" style="max-height: 300px; background: #333;" alt="Cover">
                <h5 id="modal-title" class="fw-bold mb-1">Book Title</h5>
                <p id="modal-author" class="text-secondary mb-1">Author Name</p>
                <small id="modal-meta" class="text-muted d-block mb-3">Year: 1900</small>

                <p id="modal-desc" class="text-start small mb-4 text-muted" style="max-height: 100px; overflow-y: auto;">
                    No description available for this book.
                </p>

                <button id="modal-download-btn" class="btn btn-primary w-100 fw-bold text-uppercase" onclick="startDownloadFromModal()">
                    📥 Download & Add to Calibre-Web
                </button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="calibreLoginModal" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-surface text-body border-danger">
            <div class="modal-header border-bottom-0">
                <h5 class="modal-title text-danger fw-bold">
                    🔒 Calibre-Web Connection Error
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p class="text-secondary small mb-3">
                    The stored uploader credentials failed. Please enter the current Calibre-Web admin username and password to process changes.
                </p>
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Username</label>
                    <input type="text" id="calibre-user-input" class="form-control" placeholder="admin">
                </div>
                <div class="mb-3">
                    <label class="form-label text-muted small fw-bold">Password</label>
                    <div class="input-group">
                        <input type="password" id="calibre-pass-input" class="form-control" placeholder="••••••••">
                        <button class="btn btn-outline-secondary border-start-0" type="button" id="toggle-pass-btn" onclick="togglePasswordVisibility()" style="border-color: var(--bs-border-color);">
                            👁️
                        </button>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger fw-bold" onclick="submitCalibreLogin()">Update & Retry</button>
            </div>
        </div>
    </div>
</div>
